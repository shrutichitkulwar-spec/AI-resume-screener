# Root .gitignore
# Files that should never be uploaded to GitHub

# ── Secrets ──────────────────────────────────────────────
.env
*.env

# ── Python ───────────────────────────────────────────────
__pycache__/
*.py[cod]
venv/
env/
.venv/
*.egg-info/
dist/
build/

# ── Node / React ─────────────────────────────────────────
node_modules/
frontend/build/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── OS files ─────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Editor files ─────────────────────────────────────────
.vscode/
.idea/
*.swp
